# ==============================================================================
# 1. Сборочный мусор компилятора Rust & Cargo
# ==============================================================================
/target/
**/*.rs.bk
cargo-timing.html

# Для бинарных монолитов и приложений Cargo.lock ОБЫЧНО коммитится, 
# чтобы гарантировать 100% воспроизводимость зависимостей в CI/CD (INV-008).
# Если решишь его скрыть, раскомментируй строку ниже:
# Cargo.lock

# ==============================================================================
# 2. Горячий транзакционный контур DataCopter (Игнорируем рантайм-логи)
# ==============================================================================
# Директория дискового WAL по умолчанию и её проверочные шлюзы
/wal/
.datacopter_gate
*.wal

# Локальные файлы прогресса инкрементов (state_file)
state.json
state_file
*.state

# Любые пользовательские локальные конфигурации, содержащие реальные пароли к СУБД
pipeline.local.yaml
*.secret.yaml

# ==============================================================================
# 3. Управление изолированной песочницей (sandbox/)
# ==============================================================================
# ЗАПРЕЩАЕМ игнорировать файлы .gitkeep, чтобы зафиксировать структуру папок в GitHub
!sandbox/**/.gitkeep

# Игнорируем динамические файлы локальных СУБД, создаваемые при тестах в WSL
sandbox/sqlite/*.db
sandbox/sqlite/*.db-journal
sandbox/sqlite/*.db-wal
sandbox/sqlite/*.db-shm
sandbox/duckdb/*.ddb
sandbox/duckdb/*.db

# Игнорируем локальный мусор объектного хранилища s3 и файлового плагина
sandbox/s3/chunks/
sandbox/file_storage/output/

# Блокируем случайные тяжелые дампы данных или логи брокеров/СУБД внутри песочницы
sandbox/**/*.log
sandbox/**/*.tmp
sandbox/**/.DS_Store

# ==============================================================================
# 4. Мусор сред разработки (IDE) и операционных систем
# ==============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# IntelliJ IDEA / CLion
.idea/
*.iml

# Системный мусор Windows / WSL / macOS
Thumbs.db
.DS_Store
*.swp
*~
